        {
          "name": "payment_amount",
          "value": "1060.00 CNY",
          "source": "REQ-AP-001"
        },
        {
          "name": "tax_amount",
          "value": "60.00 CNY",
          "source": "REQ-AP-001"
        },
        {
          "name": "accounting_period",
          "value": "2026-06",
          "source": "RULE-AP-POSTING"
        }
      ],
      "steps": [
        {
          "action": "Create AP payment request from validated supplier invoice INV-AP-001.",
          "input": "payment_amount=1060.00 CNY, tax_amount=60.00 CNY, period=2026-06"
        },
        {
          "action": "Approve the request with finance manager and release payment to bank.",
          "input": "manager=ACT-MANAGER, releaser=ACT-TREASURY"
        },
        {
          "action": "Receive bank accepted result and run AP settlement posting.",
          "input": "bank_reference=BNK-AP-001"
        }
      ],
      "expected": [
        {
          "assertion": "Invoice status becomes paid and remains linked to payment request PAY-AP-001.",
          "observable": "invoice_status"
        },
        {
          "assertion": "Approval chain records requester, finance manager, treasury releaser, timestamps, and no self-approval.",
          "observable": "approval_chain"
        },
        {
          "assertion": "Budget occupation is created before bank release and consumed after successful settlement.",
          "observable": "budget_occupation"
        },
        {
          "assertion": "Payment status reaches paid with bank reference BNK-AP-001.",
          "observable": "payment_status"
        },
        {
          "assertion": "Bank receipt amount, payee, bank account, currency, and external reference match the approved request.",
          "observable": "bank_receipt"
        },
        {
          "assertion": "Journal voucher is generated exactly once in period 2026-06 and debit_credit_balance holds: debit equals credit for 1060.00 CNY.",
          "observable": "journal_voucher"
        },
        {
          "assertion": "AP subledger open item is cleared and GL control account balance reflects the settlement.",
          "observable": "subledger_balance"
        },
        {
          "assertion": "Invoice, payment, bank receipt, AP subledger, GL, and report line reconcile with zero difference.",
          "observable": "reconciliation_result"
        }
      ],
      "finance": {
        "process": "ap_payment",
        "business_event": "supplier invoice payment settlement",
        "accounting_event": "settlement",
        "financial_assertions": [
          "voucher_generated",
          "debit_credit_balance",
          "subledger_gl_reconciled",
          "bank_payment_reconciled",
          "tax_amount_asserted"
        ],
        "control_assertions": [
          "approval_matrix",
          "segregation_of_duties",
          "audit_evidence"
        ],
        "regulatory_refs": [
          "LAW-ACCOUNTING",
          "CIC-BASIC"
        ]
      },
