      "id": "TC-FIN-AP-001",
      "title": "Approved supplier payment posts balanced AP settlement and reconciles bank/AP/GL",
      "priority": "P0",
      "level": "e2e",
      "type": "happy_path",
      "traceability": {
        "requirements": [
          "REQ-AP-001"
        ],
