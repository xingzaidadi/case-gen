          "TP-E2E-AP-001",
          "TP-ACCT-AP-001"
        ],
        "inferred": false
      },
      "preconditions": [
        "Accounting period 2026-06 is open.",
        "Supplier invoice INV-AP-001 is validated, not paid, and has tax amount 60.00 CNY.",
        "Budget center BUD-AP-001 has available budget above 1060.00 CNY."
