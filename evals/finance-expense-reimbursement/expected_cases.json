        {
          "assertion": "Bank receipt is linked as paid evidence.",
          "observable": "bank_receipt"
        },
        {
          "assertion": "Journal voucher is generated exactly once in period 2026-06 and debit_credit_balance holds: debit equals credit for 530.00 CNY.",
          "observable": "journal_voucher"
        },
        {
          "assertion": "Employee payable subledger clears and GL balance reflects reimbursement settlement.",
          "observable": "subledger_balance"
        },
        {
          "assertion": "Expense report, invoice, payment, bank receipt, subledger, GL, and report line reconcile with zero difference.",
          "observable": "reconciliation_result"
        }
