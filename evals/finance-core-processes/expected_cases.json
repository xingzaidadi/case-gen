        {
          "assertion": "Payment status remains approved_not_released and duplicate payment is blocked until bank-account approval completes.",
          "observable": "payment_status"
        },
        {
          "assertion": "Bank statement has no outgoing payment instruction for PAY-MDM-001.",
          "observable": "bank_statement"
        },
        {
          "assertion": "Control evidence records sensitive master-data dependency, idempotency key, duplicate payment key, and SoD rule.",
          "observable": "control_evidence"
        },
        {
          "assertion": "Audit evidence records old/new bank account, actor, timestamp, approval requirement, and release denial.",
          "observable": "audit_evidence"
