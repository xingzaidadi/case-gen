      "preconditions": [
        "Supplier S001 bank account was changed by ACT-MDM and is pending independent approval.",
        "Payment request PAY-MDM-001 references supplier S001."
      ],
      "data": [
        {
          "name": "idempotency_key",
          "value": "MDM-BANK-CHANGE-001",
